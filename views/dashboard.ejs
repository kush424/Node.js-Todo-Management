<%- include("partials/header") %>

<div class="row mb-4">

    <div class="col-md-3">
        <div class="card p-3">
            <h6>Total Tasks</h6>
            <h3><%= total %></h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h6>Pending</h6>
            <h3><%= pending %></h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h6>In Progress</h6>
            <h3><%= progress %></h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h6>Completed</h6>
            <h3><%= completed %></h3>
        </div>
    </div>

</div>

<a href="/add" class="btn btn-primary mb-3">+ Add Task</a>

<table class="table table-hover shadow-sm">

    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Priority</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

    <% tasks.forEach(t => { %>
        <tr>
            <td><%= t.title %></td>
            <td><%= t.description %></td>
            <td><%= t.priority %></td>

            <td>
                <span class="badge bg-secondary"><%= t.status %></span>
            </td>

            <td>
                <a href="/edit/<%= t.id %>" class="btn btn-sm btn-warning">Edit</a>
                <a href="/delete/<%= t.id %>" class="btn btn-sm btn-danger">Delete</a>
                <a href="/status/<%= t.id %>" class="btn btn-sm btn-info">Status</a>
            </td>
        </tr>
    <% }) %>

    </tbody>
</table>

<%- include("partials/footer") %> 